PORT=3001
DATABASE_URL=postgres://postgres:postgres@localhost:5432/fnb_forecasting
SAFETY_STOCK_PCT=0.15
ML_SERVICE_URL=http://localhost:8000
AUTO_IMPORT_DEMO_DATA=1
LLM_ENABLED=1
LLM_PROVIDER=groq

# Groq (Recommended - FREE tier, fast, works on all VPS sizes)
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI (Alternative - ~$0.01/month)
# OPENAI_API_KEY=sk_your_openai_key_here
# OPENAI_MODEL=gpt-4o-mini

# Ollama (Self-hosted - requires 8GB+ RAM)
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1
